<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Khom Property Platform</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  
  <style>
    body { font-family: 'Kanit', sans-serif; }
    .neon-blue { color: #00f3ff; text-shadow: 0 0 15px rgba(0, 243, 255, 0.6); }
    .hero-glow { background: linear-gradient(135deg, #1e3a8a 0%, #0f172a 100%); animation: heroFloat 6s ease-in-out infinite; }
    @keyframes heroFloat { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-12px); } }
    .card { transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1); }
    .card:hover { transform: translateY(-12px) scale(1.03); }
    .overlay-enter { animation: slideUp 0.4s cubic-bezier(0.32, 0.72, 0, 1) forwards; }
    @keyframes slideUp { from { transform: translateY(100%); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
    .message-enter { animation: messagePop 0.3s ease forwards; }
    @keyframes messagePop { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  </style>
</head>
<body class="max-w-md mx-auto min-h-screen pb-20 bg-gradient-to-b from-slate-50 to-slate-100 overflow-x-hidden">

  <!-- Navbar -->
  <nav class="bg-white/95 backdrop-blur-lg border-b sticky top-0 z-50 px-5 py-4 flex justify-between items-center">
    <button onclick="toggleDarkMode()" class="w-10 h-10 flex items-center justify-center text-gray-600 hover:text-indigo-600">
      <i class="fa-solid fa-moon text-xl"></i>
    </button>
    <div class="flex items-center gap-2">
      <div class="w-8 h-8 bg-gradient-to-br from-cyan-400 to-indigo-600 rounded-2xl flex items-center justify-center">
        <span class="text-white text-sm font-bold">K</span>
      </div>
      <h1 class="font-bold text-2xl tracking-tighter text-slate-900">KHOM</h1>
    </div>
    <button onclick="showSection('news')" class="w-10 h-10 flex items-center justify-center text-gray-600 hover:text-indigo-600 relative">
      <i class="fa-solid fa-bell text-xl"></i>
    </button>
  </nav>

  <!-- Main View -->
  <div id="main-view" class="p-5 space-y-8">
    <div class="hero-glow rounded-3xl p-7 text-white relative overflow-hidden shadow-2xl">
      <div class="relative z-10">
        <p class="text-cyan-300 text-sm font-medium">Khom Property Platform</p>
        <h2 id="user-greeting" class="text-3xl font-semibold mt-1">สวัสดีครับ</h2>
        <p id="room-tag" class="text-cyan-100 mt-1">ยินดีต้อนรับสู่สังคมคุณภาพ</p>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div onclick="showSection('repair')" class="card bg-white rounded-3xl p-6 shadow-sm flex flex-col items-center text-center cursor-pointer">
        <div class="w-16 h-16 bg-blue-100 text-blue-600 rounded-2xl flex items-center justify-center mb-4 text-3xl"><i class="fa-solid fa-screwdriver-wrench"></i></div>
        <p class="font-semibold">แจ้งซ่อม</p>
      </div>
      <div onclick="showSection('payment')" class="card bg-white rounded-3xl p-6 shadow-sm flex flex-col items-center text-center cursor-pointer">
        <div class="w-16 h-16 bg-indigo-100 text-indigo-600 rounded-2xl flex items-center justify-center mb-4 text-3xl"><i class="fa-solid fa-wallet"></i></div>
        <p class="font-semibold">แจ้งชำระ</p>
      </div>
      <div onclick="showSection('benefits')" class="card bg-white rounded-3xl p-6 shadow-sm flex flex-col items-center text-center cursor-pointer">
        <div class="w-16 h-16 bg-cyan-100 text-cyan-600 rounded-2xl flex items-center justify-center mb-4 text-3xl"><i class="fa-solid fa-gift"></i></div>
        <p class="font-semibold">สิทธิประโยชน์</p>
      </div>
      <div onclick="showSection('rooms')" class="card bg-white rounded-3xl p-6 shadow-sm flex flex-col items-center text-center cursor-pointer border-2 border-cyan-200">
        <div class="w-16 h-16 bg-cyan-100 text-cyan-600 rounded-2xl flex items-center justify-center mb-4 text-3xl"><i class="fa-solid fa-house"></i></div>
        <p class="font-semibold">ห้องว่าง</p>
      </div>
    </div>
  </div>

  <!-- Overlay -->
  <div id="feature-overlay" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-[100] flex items-end">
    <div id="overlay-content" class="bg-white w-full rounded-t-3xl max-h-[92%] shadow-2xl overflow-hidden overlay-enter">
      <div class="sticky top-0 bg-white border-b px-5 py-4 flex items-center gap-4">
        <button onclick="closeSection()" class="text-4xl text-gray-400">&times;</button>
        <h2 id="feature-title" class="font-semibold text-xl"></h2>
      </div>
      <div id="feature-body" class="p-5 overflow-y-auto" style="max-height: calc(92vh - 73px);"></div>
    </div>
  </div>

  <!-- Bottom Nav -->
  <div class="fixed bottom-0 left-0 right-0 max-w-md mx-auto bg-white border-t h-16 flex items-center justify-around z-50">
    <button onclick="closeSection()" class="flex-1 flex flex-col items-center py-1 text-gray-500"><i class="fa-solid fa-house text-2xl"></i><span class="text-xs">หน้าแรก</span></button>
    <button onclick="showSection('news')" class="flex-1 flex flex-col items-center py-1 text-gray-500"><i class="fa-solid fa-newspaper text-2xl"></i><span class="text-xs">ข่าว</span></button>
    <button onclick="showSection('ai')" class="bg-gradient-to-br from-indigo-700 to-blue-600 text-white w-16 h-16 rounded-3xl -mt-8 shadow-2xl flex items-center justify-center border-4 border-white"><i class="fa-solid fa-robot text-3xl neon-blue"></i></button>
    <button onclick="showSection('services')" class="flex-1 flex flex-col items-center py-1 text-gray-500"><i class="fa-solid fa-map text-2xl"></i><span class="text-xs">แผนที่</span></button>
    <button onclick="toggleLogin()" class="flex-1 flex flex-col items-center py-1 text-gray-500"><i class="fa-solid fa-user text-2xl"></i><span class="text-xs">ฉัน</span></button>
  </div>

  <script>
    // ================== CONFIG ==================
    const API_BASE = "https://script.google.com/macros/s/AKfycbyS-9rQwlgPW0NsgegvK4WnEjqYJUnN9c2n8q9Ft7Qbzf-l_nucaJ0Gm_ceaJEgeq5hhg/exec";   // ← เปลี่ยนตรงนี้หลัง Deploy

    let userData = { loggedIn: false, role: 'guest', room: '' };
    let chatHistory = [];

    async function callAPI(func, payload = {}) {
      try {
        const res = await fetch(API_BASE, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ function: func, ...payload })
        });
        return await res.json();
      } catch (err) {
        console.error(err);
        alert("เกิดข้อผิดพลาดในการเชื่อมต่อ");
        return { success: false, message: "Connection error" };
      }
    }

    // ================== UI Functions ==================
    function showSection(type) {
      const overlay = document.getElementById('feature-overlay');
      const body = document.getElementById('feature-body');
      const title = document.getElementById('feature-title');

      overlay.classList.remove('hidden');
      document.getElementById('overlay-content').classList.add('overlay-enter');

      if (type === 'rooms') {
        title.textContent = "รายการห้องว่าง";
        body.innerHTML = `
          ${userData.role === 'admin' ? `
          <div class="bg-cyan-50 p-6 rounded-3xl mb-6">
            <h4 class="font-bold mb-3">เพิ่มห้องว่าง</h4>
            <input id="nr-name" placeholder="ชื่อห้อง" class="w-full p-4 rounded-2xl border mb-3">
            <input id="nr-link" placeholder="ลิงก์ห้อง" class="w-full p-4 rounded-2xl border mb-4">
            <button onclick="addRoom()" class="w-full bg-indigo-700 text-white py-4 rounded-2xl">เพิ่มห้อง</button>
          </div>` : ''}
          <div id="room-list" class="space-y-4">กำลังโหลด...</div>
        `;
        loadRooms();
      } else if (type === 'ai') {
        title.textContent = "คุยกับ พี่คม AI";
        body.innerHTML = `
          <div id="chat-box" class="h-[65vh] overflow-y-auto bg-gray-50 p-4 rounded-3xl mb-4 space-y-4"></div>
          <div class="flex gap-2">
            <input id="chat-input" type="text" class="flex-1 p-4 rounded-3xl border" placeholder="ถามพี่คม...">
            <button onclick="sendChat()" class="bg-indigo-700 text-white w-14 h-14 rounded-3xl"><i class="fa-solid fa-paper-plane"></i></button>
          </div>
        `;
      } else if (type === 'benefits') {
        title.textContent = "สิทธิประโยชน์";
        body.innerHTML = `<div class="bg-gradient-to-br from-indigo-900 to-blue-950 text-white p-10 rounded-3xl text-center"><p class="text-5xl font-bold neon-blue my-4">14,250</p><p>บาท</p></div>`;
      } else if (type === 'repair') {
        title.textContent = "แจ้งซ่อม";
        body.innerHTML = `
          <textarea id="repair-detail" class="w-full h-40 p-5 border rounded-3xl" placeholder="รายละเอียดปัญหา..."></textarea>
          <button onclick="submitRepair()" class="mt-6 w-full bg-indigo-700 text-white py-4 rounded-3xl">ส่งการแจ้ง</button>
        `;
      }
    }

    async function loadRooms() {
      const data = await callAPI('getVacantRooms');
      const container = document.getElementById('room-list');
      if (!data.length) {
        container.innerHTML = `<p class="text-center py-10 text-gray-400">ยังไม่มีห้องว่าง</p>`;
        return;
      }
      container.innerHTML = data.map(r => `
        <div class="bg-white p-5 rounded-3xl shadow-sm flex justify-between items-center">
          <div onclick="window.open('${r.link}','_blank')" class="cursor-pointer">
            <p class="font-semibold">${r.roomName}</p>
          </div>
          \( {userData.role === 'admin' ? `<button onclick="deleteRoom( \){r.rowId})" class="text-red-500"><i class="fa-solid fa-trash"></i></button>` : ''}
        </div>
      `).join('');
    }

    async function addRoom() {
      const name = document.getElementById('nr-name').value.trim();
      const link = document.getElementById('nr-link').value.trim();
      if (!name || !link) return alert("กรุณากรอกข้อมูล");
      await callAPI('addVacantRoom', { name, link });
      alert("เพิ่มสำเร็จ");
      loadRooms();
    }

    function deleteRoom(id) {
      if (confirm("ลบห้องนี้?")) callAPI('deleteVacantRoom', { rowId: id }).then(loadRooms);
    }

    async function sendChat() {
      const input = document.getElementById('chat-input');
      const msg = input.value.trim();
      if (!msg) return;

      appendMessage('user', msg);
      chatHistory.push({ role: "user", parts: [{ text: msg }] });
      input.value = "";

      const res = await callAPI('chatWithPhiKhom', { history: chatHistory });
      appendMessage('model', res);
      chatHistory.push({ role: "model", parts: [{ text: res }] });
    }

    function appendMessage(sender, text) {
      const box = document.getElementById('chat-box');
      const div = document.createElement('div');
      div.className = `message-enter ${sender === 'user' ? 'text-right' : 'text-left'}`;
      div.innerHTML = `<div class="inline-block p-4 rounded-3xl \( {sender === 'user' ? 'bg-indigo-700 text-white' : 'bg-white shadow'}"> \){text}</div>`;
      box.appendChild(div);
      box.scrollTop = box.scrollHeight;
    }

    async function submitRepair() {
      const detail = document.getElementById('repair-detail').value.trim();
      if (!detail) return alert("กรุณากรอกรายละเอียด");
      const res = await callAPI('submitData', { sheetName: 'RepairRequests', rowData: [userData.room || 'Guest', detail] });
      alert(res.message || "ส่งข้อมูลเรียบร้อย");
      closeSection();
    }

    async function toggleLogin() {
      if (userData.loggedIn) return location.reload();
      const room = prompt("Room ID:");
      const pass = prompt("Password:");
      if (!room || !pass) return;

      const res = await callAPI('checkLogin', { room, pass });
      if (res.success) {
        userData = { loggedIn: true, ...res };
        document.getElementById('user-greeting').textContent = `สวัสดีครับ ${res.room}`;
        alert("เข้าสู่ระบบสำเร็จ");
      } else {
        alert(res.message || "รหัสผ่านไม่ถูกต้อง");
      }
    }

    function closeSection() {
      document.getElementById('feature-overlay').classList.add('hidden');
    }

    function toggleDarkMode() {
      document.documentElement.classList.toggle('dark');
    }
  </script>
</body>
</html>
